{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bw-agent",
  "identifier": "com.bw-agent.app",
  "version": "0.1.0",
  "build": {
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "bw-agent",
        "visible": false,
        "width": 480,
        "height": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "bw-agent contributors",
    "copyright": "\u00a9 2026 bw-agent contributors",
    "shortDescription": "Bitwarden SSH agent for Windows and macOS",
    "longDescription": "Desktop SSH agent that unlocks SSH keys stored in your Bitwarden vault, shows per-request approval prompts with full client process chain, and keeps an auditable access log.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
