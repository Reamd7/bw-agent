{
  "name": "bw-agent-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "rsbuild dev",
    "build": "rsbuild build",
    "stage-sidecar": "node scripts/stage-sidecar.mjs",
    "watch:sidecar": "chokidar \"crates/bw-agent/src/**/*\" -c \"cargo build -p bw-agent && pnpm stage-sidecar\" --initial --throttle 1000",
    "tauri": "tauri",
    "tauri:dev": "concurrently -n sidecar,tauri -c blue,green \"pnpm watch:sidecar\" \"tauri dev\"",
    "test": "cargo test --workspace",
    "test:unit": "echo \"[placeholder] frontend unit tests not yet implemented (owned by task2)\" && exit 0",
    "check": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets -- -D warnings",
    "check:full": "cargo clean && cargo fmt --all -- --check && cargo clippy --workspace --all-targets -- -D warnings",
    "prepare": "husky"
  },
  "dependencies": {
    "@solidjs/router": "^0.15.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.7.5",
    "@rsbuild/plugin-babel": "^1.1.2",
    "@rsbuild/plugin-solid": "^1.1.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/cli": "^2.0.0",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
